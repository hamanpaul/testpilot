testbed:
  name: lab-bench-1
  devices:
    DUT:
      role: ap
      transport: serial
      selector: COM0
      serial_port: /dev/ttyUSB0
      baudrate: 115200
    STA:
      role: sta
      transport: serial
      selector: COM1
      serial_port: /dev/ttyUSB1
      baudrate: 115200
    EndpointPC:
      role: endpoint
      transport: ssh
      host: 192.168.1.100
      user: testpilot
  variables:
    SSID_5G: testpilot5G
    KEY_5G: "00000000"
    SSID_6G: testpilot6G
    KEY_6G: "00000000"
    SSID_24G: testpilot2G
    KEY_24G: "00000000"
    # STA 6G SAE-H2E confirmed working (ocv=0 fix applied to DUT hostapd)
    sta_available_bands: [5g, 6g, 2.4g]
