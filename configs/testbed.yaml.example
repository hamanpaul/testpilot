# Testbed configuration example
# Copy to configs/testbed.yaml and adjust for your lab environment:
#   cp configs/testbed.yaml.example configs/testbed.yaml
#
# configs/testbed.yaml is git-ignored to prevent committing sensitive data.

testbed:
  name: lab-bench-1

  # serialwrap binary path (can also be set via SERIALWRAP_BIN env var)
  # serialwrap_binary: /usr/local/bin/serialwrap

  devices:
    DUT:
      role: ap
      transport: serial
      serial_port: /dev/ttyUSB0
      baudrate: 115200

    STA:
      role: sta
      transport: adb
      adb_serial: "XXXXXXXX"

    EndpointPC:
      role: endpoint
      transport: ssh
      host: 192.168.1.100
      user: testpilot

  variables:
    # sta_available_bands: which STA bands testpilot may connect during baseline.
    # List format: [5g, 6g, 2.4g]  (omit 6g if lab hardware lacks stable 6G STA support)
    # sta_available_bands: [5g, 6g, 2.4g]
    SSID_5G: TestPilot_5G
    KEY_5G: testpilot5g
    SSID_6G: TestPilot_6G
    KEY_6G: testpilot6g
    SSID_24G: TestPilot_24G
    KEY_24G: testpilot24g
